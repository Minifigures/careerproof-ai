# Supabase (required). Project URL and publishable/anon key.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# LLM providers for generation. Set ANY ONE of the free keys below (no credit
# card needed). Set several for automatic fallback if one rate-limits or errors.
GROQ_API_KEY=gsk_...
GEMINI_API_KEY=AIza...
# CEREBRAS_API_KEY=csk-...        # ~1M tokens/day free
# OPENROUTER_API_KEY=sk-or-...    # 30+ free models (":free")
# HF_API_KEY=hf_...               # Hugging Face router (rate-limited)

# Optional, paid: enable Claude later when budget allows (off unless key is set).
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: override provider models or the fallback order.
# GROQ_MODEL=llama-3.3-70b-versatile
# GEMINI_MODEL=gemini-2.0-flash
# CEREBRAS_MODEL=llama-3.3-70b
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# HF_MODEL=meta-llama/Llama-3.3-70B-Instruct
# ANTHROPIC_MODEL=claude-sonnet-4-6
# LLM_ORDER=groq,gemini,cerebras,openrouter,huggingface,anthropic

# Optional: Voyage AI enables semantic RAG over your saved profile.
# Without it, the app falls back to Postgres full-text search.
# VOYAGE_API_KEY=pa-...

# Optional: Jina Reader key for higher job-URL read limits (works without one).
# JINA_API_KEY=jina_...
